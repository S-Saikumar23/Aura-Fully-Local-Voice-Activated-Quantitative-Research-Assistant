# ============================================================
# AURA Quantitative Research Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# --- Pvporcupine Wake-Word ---
# Get a free key at https://picovoice.ai/
# Leave empty to disable wake-word (voice will record immediately)
PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here
PORCUPINE_KEYWORD_PATH=C:\path\to\Hey-Aura_en_windows.ppn

# --- Ollama LLM ---
# Recommended models by RAM:
#   8 GB RAM:  qwen2.5:3b, gemma2:2b, phi3:mini
#   16 GB RAM: llama3.2:3b, mistral:7b, qwen2.5:7b
#   32 GB RAM: llama3.1:8b, mixtral:8x7b
OLLAMA_MODEL=qwen2.5:3b

# --- Faster-Whisper STT ---
# Device options: cpu, cuda
# Compute types: int8 (cpu), float16 (cuda), float32
# Use 'cpu' and 'int8' for laptops with limited GPU VRAM
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Audio Settings ---
AUDIO_SAMPLE_RATE=16000
AUDIO_RECORD_DURATION=5

# --- PostgreSQL + pgvector ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aura_finance

# --- Embedding Model (sentence-transformers) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Sentiment Model ---
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# --- Paths ---
RESEARCH_PDF_DIR=data/research_pdfs
